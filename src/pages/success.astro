							<rect width="158.73" height="22.7714" fill="white"/>
							</clipPath>
						</defs>
					</svg>
				</a>
			</div>
			<span class="font-sans font-extralight text-sm leading-none text-white" data-usal="fade-u delay-200">
				© Ethan 2026  |  ALL RIGHTS RESERVED.
			</span>
		</div>
	</footer>
</Layout>
