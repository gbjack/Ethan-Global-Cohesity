---
import Layout from '../layouts/Layout.astro';
import EventCard from '../components/EventCard.astro';
import Form from '../components/Form.astro';
import Header from '../components/header.astro';
import SwiperCard from '../components/SwiperCard.astro';
import { Image } from 'astro:assets';
import Hero from '../assets/img-hero-2008x1130.png';
import Features1 from '../assets/img-cyber-resilience-2000x1125.png';
import Features2 from '../assets/img-randsome ware awareness-1080x1236.png'
import Features3 from '../assets/img-operational-cont-1080x1236.png'
import Features4 from '../assets/img-recovery-readiness-567x319.png'
import Features5 from '../assets/img-security-1080x1080.jpg'
import Features6 from '../assets/img-reducing-downtime-1800x1212.png'
---

<Layout>
    <Header disableCta />

	<main class="px-5">
		<div class="w-full max-w-360 mx-auto">
			<h1 class="py-[clamp(5.125rem,4rem+5vw,8.5rem)] text-left" data-usal="fade-u">
				Resilience <br>Redefined
			</h1>
			<div class="pb-10" data-usal="fade-u delay-200">
				<EventCard />
			</div>
		</div>

		<figure class="pt-0 lg:pt-8.5 relative left-1/2 right-1/2 ml-[-50vw] mr-[-50vw] w-screen" data-usal="fade-u delay-400">
			 <Image
			 src={Hero}
			 alt="A close-up of a human eye peering anxiously through a jagged hole torn in brown cardboard."
			 width="2008"
			 height="1130"
			 layout="full-width"
			 decoding="async"
			 loading="eager"
			 class="object-cover w-full h-[clamp(20rem,50vw,53.125rem)]"
			 />
        </figure>
	</main>

	<section class="px-5 py-20 sm:py-25 md:py-30 lg:py-36">
		<div class="container">
			<h2 class="w-[90%]" data-usal="fade-u">
				Building a Future-Ready Strategy for Data Recovery, Security and Business Continuity
			</h2>
		</div>
		<div class="container grid grid-cols-1 lg:grid-cols-12 gap-8 items-center pt-20 sm:pt-25 md:pt-30 lg:pt-36" data-usal="fade-u delay-200">
			<div class="hidden lg:block lg:col-span-4"></div>

			<div class="lg:col-span-8 max-w-2xl space-y-6 lg:space-y-8">

				<span class="font-sans font-extrabold leading-tight tracking-tighter text-xl md:text-2xl lg:text-[1.625rem] text-black block mb-5">
					Can Your Organisation Recover When It Matters Most?
				</span>

				<div class="space-y-5 font-sans font-extralight leading-tight text-black text-xl md:text-2xl lg:text-[1.625rem]">
					<p>
						Join Ethan Global and Cohesity for an executive lunch discussion focused on cyber resilience, operational continuity and recovery readiness in today's evolving threat landscape.
					</p>
					<p>
						Designed for senior security and technology leaders, this conversational session explores how organisations are reducing operational risk, improving recovery confidence and preparing for modern cyber threats.
					</p>
				</div>

				<a href="#registration-form" target="_self" class="bg-black border-2 border-black text-white font-display font-[950] text-5 md:text-[1.375rem] uppercase px-2 py-1 cursor-pointer mt-10 inline-block fit-content hover:bg-transparent hover:text-black hover:scale-105 transition-all duration-500 pointer-events-none opacity-50">
					Reserve Your Place
				</a>
			</div>
		</div>
	</section>

	<section class="px-5 py-20 sm:py-25 md:py-30 lg:py-36 bg-black">
		<div class="container pb-14" data-usal="fade-u">
			<h3 class="text-white">
				Your Hosts
			</h3>
		</div>
		<SwiperCard />
	</section>

	<section class="px-5 py-20 sm:py-25 md:py-30 lg:py-36">
		<div class="container space-y-4 sm:space-y-6 md:space-y-8">
			<h3 data-usal="fade-u">
				What's On <br>The Table
			</h3>
			<div class="py-3" data-usal="fade-u delay-200">
				<p class="leading-normal">
					This is not a traditional vendor presentation. The session is designed as a peer-led executive discussion around:
				</p>
			</div>
			<div class="grid grid-cols-1 gap-x-5 gap-y-15 md:grid-cols-2 lg:grid-cols-3">
				<div data-usal="fade-u">
					<div class="space-y-6">
						<Image
							src={Features1}
							alt="Cyber Resilience Strategies"
							width="2000"
							height="1125"
							layout="constrained"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4>
							Cyber Resilience Strategies
						</h4>
					</div>
				</div>
				<div data-usal="fade-u delay-200">
					<div class="space-y-6">
						<Image
							src={Features2}
							alt="Ransomware Preparedness"
							width="1080"
							height="1236"
							layout="constrained"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4>
							Ransomware Preparedness
						</h4>
					</div>
				</div>
				<div data-usal="fade-u delay-400">
					<div class="space-y-6">
						<Image
							src={Features3}
							alt='Operational Continuity'
							width="1080"
							height="1236"
							layout="constrained"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4>
							Operational <span class="hidden md:block h-0"><br></span>Continuity
						</h4>
					</div>
				</div>
				<div data-usal="fade-u">
					<div class="space-y-6">
						<Image
							src={Features4}
							alt="Recovery Readiness"
							width="567"
							height="319"
							layout="constrained"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4>
							Recovery <span class="hidden md:block h-0"><br></span>Readiness
						</h4>
					</div>
				</div>
				<div data-usal="fade-u delay-200">
					<div class="space-y-6">
						<Image
							src={Features5}
							alt="AI's Growing Impact On Security And Infrastructure"
							width="1080"
							height="1080"
							layout="constrained"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4 class="text-balance">
							AI's Growing Impact <br>On Security And Infrastructure
						</h4>
					</div>
				</div>
				<div data-usal="fade-u delay-400">
					<div class="space-y-6">
						<Image
							src={Features6}
							alt="Reducing Downtime And Operational Risk"
							width="1800"
							height="1212"
							decoding="async"
							loading="lazy"
							class="w-full h-full object-cover aspect-4/3"
						/>
						<h4 class="text-balance">
							Reducing <span class="hidden md:block h-0"><br></span>Downtime And Operational Risk
						</h4>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="px-5 pb-20 sm:pb-25 md:pb-30 lg:pb-36">
		<div class="container grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">

			<div class="lg:col-span-8 space-y-6 lg:space-y-8">

				<div class="flex gap-4 sm:gap-6" data-usal="fade-u">
					<div class="w-4.5 sm:w-5.5 bg-black shrink-0"></div>
					<h5 class="">
						Attendees will hear practical perspectives from organisations navigating increasing cyber pressure, infrastructure complexity and growing expectations around recovery confidence.
					</h5>
				</div>
			</div>
			<div class="hidden lg:block lg:col-span-4">
			</div>

		</div>
	</section>

	<section class="px-5 py-20 sm:py-25 md:py-30 lg:py-36 bg-black">
        <div class="container grid grid-cols-1 xl:grid-cols-12 gap-x-12 gap-y-6 md:gap-y-10 lg:gap-y-12 items-start">
            <!-- items-start instead of align-items-start -->

            <div class="lg:block lg:col-span-5" data-usal="fade-u">
                <h3 class="text-white mt-1">
                    Stronger <br>Together
                </h3>
            </div>

            <div class="lg:col-span-7 space-y-6 lg:space-y-8" data-usal="fade-u delay-200">
                <div class="space-y-5 font-sans font-extralight leading-normal text-white text-xl md:text-2xl lg:text-[1.625rem]">
                    <p class="text-white mt-0 pt-0">
                        Together, Ethan Global and Cohesity help Australian enterprises remain operational when it matters most.
                    </p>
                    <p class="text-white">
                        Cohesity provides a modern platform for cyber resilience, backup, ransomware protection and rapid recovery.
                    </p>
                    <p class="text-white">
                        Ethan Global delivers the local expertise, integration capability and operational execution required to turn resilience strategies into real-world operational outcomes.
                    </p>
                    <p class="font-extrabold text-white">
                        The result: Organisations don’t just invest in resilience, they operationalise it, validate it and trust it.
                    </p>
                </div>
            </div>
        </div>
    </section>

	<section class="px-5 py-20 sm:py-25 md:py-30 lg:py-36">
		<div class="container grid grid-cols-1 gap-x-12 gap-y-6 md:gap-y-10 items-start"><!-- xl:grid-cols-12 lg:gap-y-12 -->

			<div class="lg:block lg:col-span-5" data-usal="fade-u">
				<h3>
				    Thanks for Registering
				</h3>
			</div>

			<div class="lg:col-span-7 space-y-6 lg:space-y-8" id="registration-form" data-usal="fade-u delay-200">
    			<p>
    			    A member of the team will be in touch and we look forward to welcoming you to Resilience Redefined.
    			</p>
			</div>

		</div>
	</section>

	<section class="px-5">
		<div class="container border-t border-t-black py-9" data-usal="fade-u">
			<EventCard />
		</div>
	</section>

	<footer class="px-5 py-10 bg-black">
		<div class="container flex flex-col items-center gap-y-4 sm:flex-row sm:items-end sm:justify-between">
			<div class="flex gap-6" data-usal="fade-u">
				<a href="https://ethan.global/" target="Ethan Global" class="hover:scale-105 transition-transform duration-500" aria-label="Ethan Global">
					<svg xmlns="http://www.w3.org/2000/svg" width="104" height="23" viewBox="0 0 104 23" fill="none" class="w-full sm:w-auto h-3.5 sm:h-5.5">
