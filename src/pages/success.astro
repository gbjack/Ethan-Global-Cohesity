							<path d="M46.7275 0.0844727H41.2549V22.6865H46.7275V0.0844727Z" fill="white"/>
						</g>
						<defs>
							<clipPath id="clip0_2021_345">
							<rect width="103.811" height="22.7714" fill="white"/>
							</clipPath>
						</defs>
					</svg>
				</a>

				<div class="w-px max-w-px min-w-px bg-white h-6 mx-2"></div>

				<a href="https://www.cohesity.com/" target="_blank" class="hover:scale-105 transition-transform duration-500" aria-label="Cohesity">
